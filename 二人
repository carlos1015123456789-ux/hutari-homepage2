<!DOCTYPE html><html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1"><title>ふたりの秘密基地</title><style>
body{
    font-family:sans-serif;
    min-height:100vh;
    padding:15px;
    color:#444;
    overflow-x:hidden;
    background:linear-gradient(180deg,#ffd6e8,#ffe8f2,#fff5fa);
}

h1,h2{
    text-align:center;
}

h1{
    color:#ff4f92;
}

h2{
    color:#ff6ba6;
}

.center{
    text-align:center;
}

.glass,.card{
    background:rgba(255,255,255,0.75);
    backdrop-filter:blur(8px);
    border:2px solid rgba(255,255,255,0.7);
    border-radius:25px;
    box-shadow:0 8px 25px rgba(255,105,180,0.2);
}

.glass{
    padding:25px;
    margin-top:70px;
}

.card{
    padding:15px;
    margin-top:15px;
}

button{
    padding:10px 15px;
    border:none;
    border-radius:12px;
    background:linear-gradient(45deg,#ff7eb3,#ff4f92);
    color:white;
    font-size:16px;
    box-shadow:0 4px 10px rgba(255,105,180,0.3);
    margin:4px;
}

button:active{
    transform:scale(0.95);
}

input,textarea{
    border-radius:12px;
    border:1px solid #ffb6d5;
    padding:10px;
    font-size:16px;
    box-sizing:border-box;
}

textarea{
    width:95%;
    height:120px;
}

.diary{
    background:#fff5f8;
    padding:10px;
    margin-top:10px;
    border-radius:15px;
    white-space:pre-wrap;
}

.photoCard{
    background:#fff5f8;
    padding:10px;
    margin-top:12px;
    border-radius:15px;
}

.photoCard img{
    width:100%;
    border-radius:15px;
    margin-top:8px;
}

.small{
    font-size:13px;
    color:#777;
}

.heart{
    position:fixed;
    bottom:-50px;
    font-size:24px;
    animation:floatUp linear infinite;
    opacity:0.7;
    pointer-events:none;
}

.flyHeart{
    position:fixed;
    font-size:28px;
    animation:popHeart 1s ease-out forwards;
    pointer-events:none;
}

@keyframes floatUp{
    0%{transform:translateY(0) rotate(0deg);opacity:0;}
    20%{opacity:0.8;}
    100%{transform:translateY(-120vh) rotate(360deg);opacity:0;}
}

@keyframes popHeart{
    0%{transform:scale(0.5);opacity:1;}
    100%{transform:translateY(-120px) scale(1.8);opacity:0;}
}
</style></head><body><div id="passwordScreen" class="center glass">
<h1>🔒 ふたりの秘密基地</h1>
<p>合言葉を入力してね♡</p>
<input type="password" id="passwordInput">
<br><br>
<button onclick="checkPassword()">入る♡</button>
</div><div id="login" class="center glass" style="display:none;">
<h1>💕 ふたりの秘密基地</h1>
<p>あなたはどっち？</p>
<button onclick="login('ゆうき')">ゆうき</button>
<button onclick="login('さき')">さき</button>
</div><div id="main" style="display:none;"><h1>💕 ふたりの秘密基地</h1>
<p id="welcome" class="center"></p><div class="card">
<h2>🎂 記念日</h2>
<p id="days"></p>
</div><div class="card">
<h2>💕 好きカウンター</h2>
<p id="loveCount">0 好き♡</p>
<button onclick="addLove(event)">好き♡</button>
</div><div class="card">
<h2>💌 交換日記</h2>
<textarea id="diaryText" placeholder="今日の気持ちを書く♡"></textarea>
<br><br>
<button onclick="saveDiary(event)">日記を投稿</button>
<div id="diaryList"></div>
</div><div class="card">
<h2>📷 思い出アルバム</h2><input type="file" id="photoInput" accept="image/*">
<br><br><textarea id="photoComment" placeholder="写真のコメントを書く♡"></textarea><br><br>

<button onclick="savePhoto(event)">写真を投稿</button>

<p class="small">※今はこのスマホのブラウザ内に保存されるよ</p><div id="photoList"></div>
</div></div><script>
function checkPassword(){
    const pass = document.getElementById("passwordInput").value;

    if(pass.toUpperCase() === "YS"){
        document.getElementById("passwordScreen").style.display = "none";
        document.getElementById("login").style.display = "block";
    }else{
        alert("合言葉が違うよ♡");
    }
}

let currentUser = "";

function login(name){
    currentUser = name;
    document.getElementById("login").style.display = "none";
    document.getElementById("main").style.display = "block";

    document.getElementById("welcome").innerText =
    "おかえり、" + name + "♡";
}

const startDate = new Date("2025-12-15");
const today = new Date();

const diff =
Math.floor((today - startDate) / (1000*60*60*24));

document.getElementById("days").innerText =
"付き合って " + diff + " 日♡";

let loveCount =
localStorage.getItem("loveCount") || 0;

document.getElementById("loveCount").innerText =
loveCount + " 好き♡";

function addLove(event){
    loveCount++;

    localStorage.setItem("loveCount", loveCount);

    document.getElementById("loveCount").innerText =
    loveCount + " 好き♡";

    popHeart(event.clientX,event.clientY,"💖");
}

function saveDiary(event){
    const text = document.getElementById("diaryText").value;

    if(text === ""){
        alert("日記を書いてね♡");
        return;
    }

    let diaries =
    JSON.parse(localStorage.getItem("diaries") || "[]");

    const date =
    new Date().toLocaleDateString("ja-JP");

    diaries.unshift(
        date + "\n" +
        currentUser + "：\n" +
        text
    );

    localStorage.setItem("diaries",JSON.stringify(diaries));

    document.getElementById("diaryText").value = "";

    showDiaries();
    burstHeart(event.clientX,event.clientY);
}

function showDiaries(){
    const area = document.getElementById("diaryList");
    area.innerHTML = "";

    const diaries =
    JSON.parse(localStorage.getItem("diaries") || "[]");

    diaries.forEach(function(d){
        const div = document.createElement("div");
        div.className = "diary";
        div.innerText = d;
        area.appendChild(div);
    });
}

function savePhoto(event){
    const file =
    document.getElementById("photoInput").files[0];

    const comment =
    document.getElementById("photoComment").value;

    if(!file){
        alert("写真を選んでね♡");
        return;
    }

    const reader = new FileReader();

    reader.onload = function(){
        const img = new Image();

        img.onload = function(){
            const canvas = document.createElement("canvas");
            const maxSize = 700;

            let width = img.width;
            let height = img.height;

            if(width > height && width > maxSize){
                height = height * maxSize / width;
                width = maxSize;
            }

            if(height >= width && height > maxSize){
                width = width * maxSize / height;
                height = maxSize;
            }

            canvas.width = width;
            canvas.height = height;

            const ctx = canvas.getContext("2d");
            ctx.drawImage(img,0,0,width,height);

            const smallImage =
            canvas.toDataURL("image/jpeg",0.75);

            let photos =
            JSON.parse(localStorage.getItem("photos") || "[]");

            const date =
            new Date().toLocaleDateString("ja-JP");

            photos.unshift({
                user:currentUser,
                date:date,
                comment:comment,
                image:smallImage
            });

            localStorage.setItem("photos",JSON.stringify(photos));

            document.getElementById("photoInput").value = "";
            document.getElementById("photoComment").value = "";

            showPhotos();
            burstHeart(event.clientX,event.clientY);
        };

        img.src = reader.result;
    };

    reader.readAsDataURL(file);
}

function showPhotos(){
    const area = document.getElementById("photoList");
    area.innerHTML = "";

    const photos =
    JSON.parse(localStorage.getItem("photos") || "[]");

    photos.forEach(function(p,index){
        const div = document.createElement("div");
        div.className = "photoCard";

        div.innerHTML =
        "<div class='small'>" +
        p.date + " / " + p.user +
        "</div>" +
        "<img src='" + p.image + "'>" +
        "<p>" + p.comment + "</p>" +
        "<button onclick='deletePhoto(" + index + ")'>削除</button>";

        area.appendChild(div);
    });
}

function deletePhoto(index){
    if(!confirm("この写真を消す？")){
        return;
    }

    let photos =
    JSON.parse(localStorage.getItem("photos") || "[]");

    photos.splice(index,1);

    localStorage.setItem("photos",JSON.stringify(photos));

    showPhotos();
}

function createHeart(){
    const heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = "💖";

    heart.style.left = Math.random()*100 + "vw";
    heart.style.fontSize = (18 + Math.random()*24) + "px";
    heart.style.animationDuration = (6 + Math.random()*8) + "s";

    document.body.appendChild(heart);

    setTimeout(function(){
        heart.remove();
    },15000);
}

function popHeart(x,y,mark){
    const heart = document.createElement("div");
    heart.className = "flyHeart";
    heart.innerHTML = mark;

    heart.style.left = x + "px";
    heart.style.top = y + "px";

    document.body.appendChild(heart);

    setTimeout(function(){
        heart.remove();
    },1000);
}

function burstHeart(x,y){
    for(let i=0;i<8;i++){
        setTimeout(function(){
            popHeart(
                x + Math.random()*80 - 40,
                y + Math.random()*80 - 40,
                "💕"
            );
        },i*80);
    }
}

showDiaries();
showPhotos();

setInterval(createHeart,900);
</script></body>
</html>
